# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# TELEGRAM_BOT_TOKEN: Telegram Bot Token from BotFather to run the real bot.
TELEGRAM_BOT_TOKEN="MY_TELEGRAM_BOT_TOKEN"

# TELEGRAM_API_BASE: Custom base URL for Telegram Bot API (useful for proxies/workers)
TELEGRAM_API_BASE="https://api.telegram.org"

# EVE_CLIENT_ID: Client ID for Eve Online Developer application SSO.
EVE_CLIENT_ID="MY_EVE_CLIENT_ID"

# EVE_CLIENT_SECRET: Client Secret for Eve Online Developer application SSO.
EVE_CLIENT_SECRET="MY_EVE_CLIENT_SECRET"

# FORCE_TELEGRAM_POLLING: Set to "true" on your production VPS if APP_URL contains ".run.app"
# but you want the local PM2 process to run the Telegram command listener loop anyway.
FORCE_TELEGRAM_POLLING="false"

# ALLOW_PUBLIC_ADMIN: Set to "true" on your production VPS to bypass the localhost security restriction
# and allow access to the web administration panel from any external IP address.
ALLOW_PUBLIC_ADMIN="false"



